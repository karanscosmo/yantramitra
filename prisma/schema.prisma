generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String
  role            String    @default("operator")
  googleId        String?   @unique
  provider        String?   @default("email")
  emailVerified   Boolean   @default(false)
  lastLoginMethod String?
  avatar          String?
  phone           String?
  prefs           Json?
  integrations    Json?
  sessions        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Plant {
  id          String     @id @default(uuid())
  name        String
  location    String
  domain      String?
  status      String     @default("operational")
  image       String?
  lat         Float?
  lng         Float?
  oee         Float?
  uptime      Float?
  floorLayout Json?
  energyUsage Float?
  co2Tonnes   Float?
  utilization Float?
  machines    Machine[]
  buildings   Building[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Building {
  id        String           @id @default(uuid())
  name      String
  code      String?
  plantId   String
  plant     Plant            @relation(fields: [plantId], references: [id])
  lines     ProductionLine[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ProductionLine {
  id         String    @id @default(uuid())
  name       String
  code       String?
  buildingId String
  building   Building  @relation(fields: [buildingId], references: [id])
  machines   Machine[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Machine {
  id                  String                @id @default(uuid())
  name                String
  serial              String?
  manufacturer        String?
  installationDate    DateTime?
  criticality         String?
  oee                 Float?
  failureProbability  Float?
  remainingUsefulLife Int?
  bearing             String?
  lubrication         String?
  aiSummary           String?
  type                String
  status              String                @default("running")
  health              Float                 @default(100.0)
  location            String?
  posX                Float?
  posZ                Float?
  rotation            Float?
  plantId             String
  plant               Plant                 @relation(fields: [plantId], references: [id])
  productionLineId    String?
  productionLine      ProductionLine?       @relation(fields: [productionLineId], references: [id])
  readings            SensorReading[]
  sensors             MachineSensor[]
  components          Component[]
  inventoryParts      InventoryPart[]
  maintenanceEvents   MaintenanceEvent[]
  alarms              Alarm[]
  workOrders          WorkOrder[]
  incidents           OperationalIncident[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model Component {
  id        String          @id @default(uuid())
  name      String
  type      String?
  health    Float           @default(100.0)
  machineId String
  machine   Machine         @relation(fields: [machineId], references: [id])
  sensors   MachineSensor[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model MachineSensor {
  id          String     @id @default(uuid())
  tag         String
  metric      String
  unit        String
  status      String     @default("normal")
  machineId   String
  machine     Machine    @relation(fields: [machineId], references: [id])
  componentId String?
  component   Component? @relation(fields: [componentId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model InventoryPart {
  id        String   @id @default(uuid())
  sku       String
  name      String
  quantity  Int      @default(0)
  reorderAt Int      @default(1)
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceEvent {
  id          String   @id @default(uuid())
  title       String
  notes       String?
  performedBy String?
  performedAt DateTime @default(now())
  machineId   String
  machine     Machine  @relation(fields: [machineId], references: [id])
}

model SensorReading {
  id        String   @id @default(uuid())
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id])
  metric    String
  value     Float
  unit      String
  timestamp DateTime @default(now())
}

model Alarm {
  id         String    @id @default(uuid())
  machineId  String
  machine    Machine   @relation(fields: [machineId], references: [id])
  severity   String
  title      String
  message    String
  status     String    @default("active")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}

model Agent {
  id             String   @id @default(uuid())
  name           String
  type           String
  status         String   @default("idle")
  model          String
  mission        String?
  progress       Int      @default(0)
  memory         Json?
  missionHistory Json?
  recentActions  Json?
  successRate    Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Plan {
  id          String    @id @default(uuid())
  title       String
  description String?
  type        String
  status      String    @default("pending")
  priority    String    @default("medium")
  createdBy   String
  approvedBy  String?
  plantId     String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WorkOrder {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("open")
  priority    String   @default("medium")
  machineId   String?
  machine     Machine? @relation(fields: [machineId], references: [id])
  assignedTo  String?
  createdBy   String
  dueDate     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OperationalIncident {
  id              String    @id @default(uuid())
  title           String
  severity        String
  status          String    @default("active")
  stage           String    @default("detected")
  rootCause       String?
  impactCost      Float?
  downtimeMinutes Int?
  assignedAgent   String?
  machineId       String
  machine         Machine   @relation(fields: [machineId], references: [id])
  alarmId         String?
  planId          String?
  workOrderId     String?
  timeline        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  recoveredAt     DateTime?
}

model Notification {
  id         String    @id @default(uuid())
  userId     String?
  title      String
  message    String
  type       String    @default("info")
  priority   String    @default("medium")
  status     String    @default("unread")
  link       String?
  createdAt  DateTime  @default(now())
  archivedAt DateTime?
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  detail    Json?
  createdAt DateTime @default(now())
}
