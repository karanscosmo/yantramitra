# ──────────────────────────────────────
# Database — Postgres via Neon (required)
# ──────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech:5432/neondb?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech:5432/neondb"

# ──────────────────────────────────────
# JWT secret key (required)
# ──────────────────────────────────────
JWT_SECRET="your-strong-random-jwt-secret-here"

# ──────────────────────────────────────
# AI Chat — YantraNklan (required for AI features)
# ──────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GROQ_API_KEY="your-groq-api-key-here"

# ──────────────────────────────────────
# Demo-only password reset
# ──────────────────────────────────────
ENABLE_DEMO_PASSWORD_RESET="false"
