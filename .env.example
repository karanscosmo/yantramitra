# ──────────────────────────────────────
# Database — Postgres via Neon (required)
# ──────────────────────────────────────
# DATABASE_URL: Pooled connection string for runtime (Vercel serverless).
#   Hostname includes "-pooler". Prisma uses this at runtime.
#   Format: postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech:5432/neondb?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech:5432/neondb?pgbouncer=true&connection_limit=1"

# DIRECT_URL: Direct (non-pooled) connection string for migrations and seed.
#   Hostname has NO "-pooler". Prisma uses this only for db push / migrate / seed.
#   Format: postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech:5432/neondb
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech:5432/neondb"

# ──────────────────────────────────────
# JWT secret key (required)
# ──────────────────────────────────────
# Generate one locally:  openssl rand -hex 32
JWT_SECRET="your-strong-random-jwt-secret-here"

# ──────────────────────────────────────
# AI Chat — YantraNklan (optional)
# ──────────────────────────────────────
# Set this for the YantraNklan AI assistant to work.
# If it is missing, the chat will show a setup prompt instead of failing silently.
OPENAI_API_KEY="your-openai-api-key-here"

# ──────────────────────────────────────
# Demo-only password reset
# ──────────────────────────────────────
# Leave false for production. The app needs a real email-token reset flow before
# enabling public password resets for company users.
ENABLE_DEMO_PASSWORD_RESET="false"
